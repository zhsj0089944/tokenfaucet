	"license": "MIT",
	"homepage": "https://github.com/zhsj0089944/tokenfaucet",
	"scripts": {
		"dev": "next dev --turbo",
		"build": "next build",
		"build:docker": "next build",
		"start": "next start",
		"lint": "biome check --write .",
		"lint:check": "biome check .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"test": "vitest run",
		"test:dev": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"type-check": "tsc --noEmit",
		"clean": "rm -rf .next dist coverage",
		"db:generate": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit studio",
		"db:push": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit push",
		"prepare": "husky || true",
		"ci": "pnpm run type-check && pnpm run lint:check && pnpm run test",
		"fix:quick": "pnpm lint && pnpm format",
		"quality:check": "pnpm run type-check && pnpm run lint:check && pnpm run format:check && pnpm run test:coverage",
		"quality:fix": "pnpm run format && pnpm run lint && pnpm run test",
		"deps:check": "pnpm outdated",
		"deps:update": "pnpm update --latest",
		"docs:dev": "next dev docs",
		"docs:build": "next build docs",
		"test:unit": "vitest run --reporter=verbose",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:e2e": "playwright test"
	},
