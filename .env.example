# TokenFaucet Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# DATABASE (Required)
# =============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/tokenfaucet

# Database connection pool settings
DB_POOL_MAX=20
DB_POOL_MIN=5

# Database SSL setting ("false" to disable, "true" to enable)
DATABASE_SSL=false

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================
# Better Auth secret (minimum 32 characters)
BETTER_AUTH_SECRET=your-secret-key-here-must-be-at-least-32-characters-long

# Better Auth URL (optional, defaults to NEXT_PUBLIC_SITE_URL)
BETTER_AUTH_URL=https://your-domain.com

# Better Auth cookie domain (optional)
BETTER_AUTH_COOKIE_DOMAIN=your-domain.com

# Admin emails (comma-separated)
ADMIN_EMAILS=admin@example.com

# =============================================================================
# PAYMENT - Creem (Optional)
# =============================================================================
CREEM_API_KEY=creem_...
CREEM_WEBHOOK_SECRET=whsec_...

# =============================================================================
# SITE CONFIGURATION (Required)
# =============================================================================
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com

# =============================================================================
# AUTH URLS (Optional - have defaults)
# =============================================================================
NEXT_PUBLIC_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_SIGN_UP_URL=/auth/register
NEXT_PUBLIC_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_SIGN_UP_FALLBACK_REDIRECT_URL=/

# =============================================================================
# FEATURE FLAGS (Optional - have defaults)
# =============================================================================
# Server-side feature flags
ENABLE_AI_FEATURES=true
ENABLE_PAYMENT_FEATURES=true
ENABLE_ADMIN_FEATURES=true

# Client-side feature flags
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_PAYMENT_FEATURES=true

# =============================================================================
# INTERNATIONALIZATION (Optional - have defaults)
# =============================================================================
NEXT_PUBLIC_DEFAULT_LOCALE=zh
NEXT_PUBLIC_SUPPORTED_LOCALES=zh,en

# =============================================================================
# REDIS - Upstash (Optional - for rate limiting)
# =============================================================================
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# =============================================================================
# EMAIL SERVICE - Resend (Optional)
# =============================================================================
RESEND_API_KEY=re_...

# Support email forwarding
SUPPORT_FORWARD_EMAIL=support@your-domain.com
RESEND_WEBHOOK_SECRET=whsec_...

# =============================================================================
# CLOUDFLARE (Optional)
# =============================================================================
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_API_TOKEN=...

# Cloudflare Turnstile (human verification)
TURNSTILE_SECRET_KEY=0x...
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...

# =============================================================================
# GOOGLE OAUTH (Optional)
# =============================================================================
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
NEXT_PUBLIC_GOOGLE_CLIENT_ID=...

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================
# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...

# Google Site Verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=...

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=...
NEXT_PUBLIC_POSTHOG_HOST=...

# =============================================================================
# MONITORING (Optional)
# =============================================================================
# Sentry
SENTRY_DSN=https://...
NEXT_PUBLIC_SENTRY_DSN=https://...

# Slack webhook for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# =============================================================================
# CRON & INTERNAL API (Optional)
# =============================================================================
# Cron secret for scheduled tasks (minimum 16 characters)
CRON_SECRET=your-cron-secret-min-16-chars

# Internal API key for internal tRPC endpoints (minimum 16 characters)
INTERNAL_API_KEY=your-internal-api-key-min-16-chars

# =============================================================================
# BACKUP (Optional)
# =============================================================================
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================
NODE_ENV=development